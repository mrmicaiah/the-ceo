# Bearer token the agent presents on the websocket upgrade. Must match the
# AUTH_TOKEN... actually AGENT_TOKEN... secret on the deployed Worker.
AGENT_TOKEN=replace-me

# The Worker's WebSocket endpoint. Use wss:// for the deployed Worker and
# ws:// for local wrangler dev.
#   Production: wss://the-ceo.micaiah-tasks.workers.dev/api/agent/ws
#   Local dev:  ws://localhost:8787/api/agent/ws
WORKER_URL=wss://the-ceo.micaiah-tasks.workers.dev/api/agent/ws

# Where the agent clones / works in repos on this machine. The agent will
# `git clone` projects into <REPOS_DIR>/<repo-name> if they don't exist yet.
REPOS_DIR=C:\Users\mrmic\Projects

# Anthropic API key for the Claude Code SDK to use during job execution.
# Same key as the Worker's ANTHROPIC_API_KEY is fine.
ANTHROPIC_API_KEY=sk-ant-...
